{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "language": { "type": "string", "enum": ["en", "tl"] },
        "pin": { "type": "string", "description": "Hashed PIN for app lock" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "language", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Income or expense record",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "note": { "type": "string" },
        "isRecurring": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "amount", "type", "category", "date", "createdAt"]
    },
    "Loan": {
      "title": "Loan",
      "description": "Utang tracker (lent or borrowed)",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["lent", "borrowed"] },
        "person": { "type": "string" },
        "amount": { "type": "number" },
        "dueDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "paid"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "person", "amount", "status", "createdAt"]
    },
    "Paluwagan": {
      "title": "Paluwagan",
      "description": "Group savings tracker",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "totalAmount": { "type": "number" },
        "contributionAmount": { "type": "number" },
        "frequency": { "type": "string", "enum": ["daily", "weekly", "bi-weekly", "monthly"] },
        "myTurnDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "totalAmount", "contributionAmount", "frequency", "status", "createdAt"]
    },
    "Bill": {
      "title": "Bill",
      "description": "Bill reminder",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "amount": { "type": "number" },
        "dueDate": { "type": "string", "format": "date-time" },
        "isPaid": { "type": "boolean" },
        "isRecurring": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "amount", "dueDate", "isPaid", "createdAt"]
    },
    "Category": {
      "title": "Category",
      "description": "Custom transaction category",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "type", "createdAt"]
    },
    "Goal": {
      "title": "Goal",
      "description": "Monthly budget goal for a category",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "month": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "category", "amount", "month", "createdAt"]
    }
  },
  "firestore": {
    "/goals/{goalId}": {
      "schema": { "$ref": "#/entities/Goal" },
      "description": "User budget goals"
    },
    "/categories/{categoryId}": {
      "schema": { "$ref": "#/entities/Category" },
      "description": "User custom categories"
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "User transactions"
    },
    "/loans/{loanId}": {
      "schema": { "$ref": "#/entities/Loan" },
      "description": "User loans (utang)"
    },
    "/paluwagan/{paluwaganId}": {
      "schema": { "$ref": "#/entities/Paluwagan" },
      "description": "User paluwagan groups"
    },
    "/bills/{billId}": {
      "schema": { "$ref": "#/entities/Bill" },
      "description": "User bills"
    }
  }
}
